    D --> E3["Worker thread ..."]
    D --> E4["Worker thread N"]
    E1 --> F["Compute independent pixels\nz(n+1)=z(n)^2+c"]
    E2 --> F
    E3 --> F
    E4 --> F
    F --> G["Write iteration counts\nto disjoint output array regions"]
    G --> H["Convert iteration array\nto PNG image / benchmark result"]
